# ================================================================
# LOCAL DEV CONFIG — optimised for limited resources (no GPU)
# Copy to src/.env: cp src/.env.local.example src/.env
# ================================================================

# ======================== App Info ========================
APP_NAME="Siraj"
APP_VERSION="3.0.0"

# ======================== File Config =====================
FILE_ALLOWED_TYPES=["text/plain", "application/pdf"]
FILE_MAX_SIZE=10
FILE_DEFAULT_CHUNK_SIZE=512000

# ======================== Postgres Config =================
POSTGRES_USERNAME="postgres"
POSTGRES_PASSWORD="local_dev_password"
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_MAIN_DATABASE="RagApp"

# ======================== LLM Config =====================
# --- Option A: OpenAI API (cheapest, no local GPU needed) ---
GENERATION_BACKEND="openai"
GENERATION_MODEL_ID="gpt-4o-mini"
GENERATION_MODEL_ID_LITERAL=["gpt-4o-mini", "gpt-4o"]
OPENAI_API_KEY="your_openai_api_key"
OPENAI_API_URL="https://api.openai.com/v1/"

# --- Option B: Ollama (fully offline, ~1.5 GB RAM) -----------
# Install: https://ollama.com  then: ollama pull gemma2:2b
# GENERATION_BACKEND="openai"           # Ollama speaks OpenAI protocol
# GENERATION_MODEL_ID="gemma2:2b"
# OPENAI_API_KEY="ollama"               # any non-empty string
# OPENAI_API_URL="http://localhost:11434/v1/"

COHERE_API_KEY=""

# ⚠ Keep typos — LLMProviderFactory reads these exact key names
INPUT_DAFAULT_MAX_CHARACTERS=1024
GENERATION_DAFAULT_MAX_TOKENS=200
GENERATION_DAFAULT_TEMPERATURE=0.1

# ======================== Embedding Config ================
# Small CPU-friendly model (~130 MB, 384-dim) — fast on 8 cores
# Change to intfloat/e5-large-v2 (1024-dim, ~1.3 GB) when GPU works
EMBEDDING_BACKEND="open_source_embeddings"
EMBEDDING_MODEL_ID="BAAI/bge-small-en-v1.5"
EMBEDDING_MODEL_SIZE=384

# ======================== Vector DB Config ================
VECTOR_DB_BACKEND="PGVECTOR"
VECTOR_DB_BACKEND_LITERAL=["QDRANT", "PGVECTOR"]
VECTOR_DB_PATH="qdrant_db"
VECTOR_DB_METHOD="cosine"
VECTOR_DB_PGVEC_INDEX_THRESHOLD=200

# ======================== Template Config =================
DEFAULT_LANG="en"
PRIMARY_LANG="en"
